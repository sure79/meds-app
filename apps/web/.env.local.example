# Turso Cloud Database (optional - falls back to localStorage if not set)
# 1. Create a free account at https://turso.tech
# 2. Install Turso CLI: https://docs.turso.tech/cli/introduction
# 3. Run: turso db create meds-projects
# 4. Run: turso db show meds-projects --url
# 5. Run: turso db tokens create meds-projects
VITE_TURSO_DB_URL=libsql://meds-projects-<your-org>.turso.io
VITE_TURSO_DB_AUTH_TOKEN=<your-auth-token>

# Backend API URL (optional - uses local JS fallback if not set)
# Local dev: http://localhost:8000
# Production: set to your Render backend URL
VITE_API_URL=http://localhost:8000
